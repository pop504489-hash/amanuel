rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SECURITY RULES DOCUMENTATION
     * 
     * Core Philosophy:
     * This ruleset employs a strict Path-Based Ownership model for user-specific data and a 
     * Database Access Control (DBAC) model for administrative tasks.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated with any provider. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user is authenticated and NOT anonymous. */
    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user has an entry in the admin roles collection. */
    function isAdmin() {
      // In this prototype, we check for verified (email/password) users. 
      return isVerifiedUser();
    }

    // --- COLLECTION RULES ---

    /**
     * @description Global product catalog. 
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Root level orders collection.
     * Allows any authenticated shop to create an order.
     * Allows admins to list, get, and update order statuses.
     */
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if isAdmin();
    }

    /**
     * @description User profile for shop metadata.
     */
    match /users/{userId}/profile/{profileId} {
      allow get, list: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false; 
    }

    /**
     * @description Legacy nested orders (maintained for path consistency if needed).
     */
    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);

      match /orderItems/{orderItemId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }
  }
}