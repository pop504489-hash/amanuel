rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SIMPLE B2B INVENTORY ORDERING PLATFORM - SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a dual-access model for a B2B marketplace. It separates 
     * administrative control (managed via a dedicated admin collection) from shop-specific 
     * commerce operations. Access is strictly governed by authenticated identity and 
     * ownership of data paths.
     *
     * DATA STRUCTURE:
     * - /admin_users/{uid}: Defines administrative privileges.
     * - /products/{id}: Global catalog managed by admins, readable by all shops.
     * - /shops/{shopId}: Private profile for each shop owner.
     * - /shops/{shopId}/orders/{orderId}: Hierarchical order management.
     *
     * KEY SECURITY DECISIONS:
     * 1. Path-Based Ownership: Shop owners are restricted to their own /shops/{shopId} 
     *    tree using their Firebase UID.
     * 2. Administrative Override: Users present in the 'admin_users' collection are 
     *    granted read/write access across all collections to manage inventory and fulfillment.
     * 3. Public Catalog: Products are readable by any authenticated shop user to 
     *    facilitate browsing, but modification is strictly restricted to admins.
     * 4. Relational Integrity: Critical fields like 'shopId' in orders are enforced 
     *    to match the path to prevent data spoofing.
     *
     * DENORMALIZATION FOR AUTHORIZATION:
     * - Administrative status is verified by checking for the existence of a document 
     *   in the 'admin_users' collection corresponding to the requester's UID.
     * - Order ownership is verified by the {shopId} segment in the document path, 
     *   which must match the user's UID.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user is the owner of the document based on its path ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user exists in the admin_users collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    /** @description Combines ownership check with existence check for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Verifies a field is not being changed during an update. */
    function isImmutable(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- Collection Rules ---

    /**
     * @description Rules for administrative user profiles.
     * @path /admin_users/{adminId}
     * @allow (get) if request.auth.uid == 'admin_123' (User is the admin).
     * @deny (create) if request.auth.uid != adminId (Cannot create admin record for others).
     * @principle Ensures only the platform owner can access or manage their admin profile.
     */
    match /admin_users/{adminId} {
      allow get, list: if isOwner(adminId);
      allow create: if isOwner(adminId) && request.resource.data.id == adminId;
      allow update: if isExistingOwner(adminId) && isImmutable('id');
      allow delete: if isExistingOwner(adminId);
    }

    /**
     * @description Rules for shop profiles.
     * @path /shops/{shopId}
     * @allow (get) if request.auth.uid == shopId || isAdmin().
     * @deny (update) if user is not the shop owner and not an admin.
     * @principle Grants shop owners access to their own profile while allowing admin oversight.
     */
    match /shops/{shopId} {
      allow get, list: if isOwner(shopId) || isAdmin();
      allow create: if (isOwner(shopId) && request.resource.data.id == shopId) || isAdmin();
      allow update: if (isExistingOwner(shopId) && isImmutable('id')) || (resource != null && isAdmin());
      allow delete: if (isExistingOwner(shopId)) || (resource != null && isAdmin());

      /**
       * @description Rules for orders placed by a shop.
       * @path /shops/{shopId}/orders/{orderId}
       * @allow (create) if shopId == request.auth.uid (Shop owner placing an order).
       * @deny (list) if request.auth.uid != shopId && !isAdmin() (Prevent snooping).
       * @principle Hierarchical ownership ensures orders are private to shops and accessible to admins.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(shopId) || isAdmin();
        allow create: if (isOwner(shopId) && request.resource.data.shopId == shopId) || isAdmin();
        allow update: if (isExistingOwner(shopId) && isImmutable('shopId')) || (resource != null && isAdmin());
        allow delete: if (isExistingOwner(shopId)) || (resource != null && isAdmin());

        /**
         * @description Rules for individual items within an order.
         * @path /shops/{shopId}/orders/{orderId}/order_items/{orderItemId}
         * @allow (get) if isOwner(shopId) (Owner viewing their order details).
         * @deny (write) if !isOwner(shopId) && !isAdmin().
         * @principle Inherited authorization from the parent shop context.
         */
        match /order_items/{orderItemId} {
          allow get, list: if isOwner(shopId) || isAdmin();
          allow create: if (isOwner(shopId) && request.resource.data.orderId == orderId) || isAdmin();
          allow update: if (isExistingOwner(shopId) && isImmutable('orderId')) || (resource != null && isAdmin());
          allow delete: if (isExistingOwner(shopId)) || (resource != null && isAdmin());
        }
      }
    }

    /**
     * @description Rules for the product catalog.
     * @path /products/{productId}
     * @allow (list) if isSignedIn() (Authenticated shops can browse products).
     * @deny (create) if !isAdmin() (Only admins can add products).
     * @principle Implements a Public Read / Admin-Only Write pattern for the inventory catalog.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if resource != null && isAdmin();
      allow delete: if resource != null && isAdmin();
    }
  }
}